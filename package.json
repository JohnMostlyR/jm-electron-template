{
  "name": "root",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "turbo run build",
    "clean": "git clean -xdf .turbo logs node_modules",
    "clean:workspaces": "turbo run clean",
    "coverage": "turbo run coverage",
    "deps:check": "pnpm update --recursive --interactive",
    "deps:verify": "pnpm lint:repo && pnpm typecheck && pnpm test",
    "format": "turbo run format --continue -- --cache --cache-location .cache/.prettiercache",
    "format:fix": "turbo run format --continue -- --write --cache --cache-location .cache/.prettiercache",
    "format:pkg": "pnpm dlx sort-package-json@latest \"package.json\" \"**/package.json\" --ignore \"**/node_modules/**\"",
    "postinstall": "pnpm lint:repo",
    "lint": "turbo run lint --continue -- --cache --cache-location .cache/.eslintcache",
    "lint:fix": "turbo run lint --continue -- --fix --cache --cache-location .cache/.eslintcache",
    "lint:repo": "pnpm sync:lint",
    "sync:lint": "syncpack lint",
    "sync:versions": "syncpack fix-mismatches",
    "test": "turbo run test --continue",
    "test:watch": "turbo run test:watch",
    "typecheck": "turbo run typecheck --continue"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@manypkg/cli": "^0.25.1",
    "@turbo/gen": "^2.9.3",
    "@types/node": "catalog:",
    "syncpack": "^13.0.4",
    "ts-morph": "27.0.2",
    "turbo": "^2.9.3",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  }
}
